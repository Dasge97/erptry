{
  "name": "@erptry/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/main.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "lint": "eslint src --ext .ts",
    "start": "node dist/main.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@erptry/contracts": "workspace:*",
    "@erptry/domain": "workspace:*",
    "@prisma/client": "^6.6.0",
    "@fastify/cors": "^11.0.1",
    "@fastify/sensible": "^6.0.3",
    "bcryptjs": "^3.0.2",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "prisma": "^6.6.0",
    "tsx": "^4.19.3"
  }
}
