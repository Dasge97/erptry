FROM node:22-alpine AS builder

WORKDIR /workspace

RUN corepack enable && corepack prepare pnpm@10.8.1 --activate

ENV INTERNAL_API_BASE_URL=http://api:3001

COPY . .

RUN pnpm install --frozen-lockfile
RUN pnpm --filter @erptry/contracts build \
  && pnpm --filter @erptry/domain build \
  && pnpm --filter @erptry/ui build \
  && pnpm --filter @erptry/web build

FROM node:22-alpine AS runner

WORKDIR /workspace

RUN corepack enable && corepack prepare pnpm@10.8.1 --activate

ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
ENV INTERNAL_API_BASE_URL=http://api:3001
ENV NEXT_PUBLIC_API_BASE_URL=

COPY --from=builder /workspace/package.json /workspace/pnpm-lock.yaml /workspace/pnpm-workspace.yaml ./
COPY --from=builder /workspace/apps ./apps
COPY --from=builder /workspace/packages ./packages
COPY --from=builder /workspace/node_modules ./node_modules

EXPOSE 3000

CMD ["sh", "-c", "cd /workspace/apps/web && ./node_modules/.bin/next start --hostname 0.0.0.0 --port 3000"]
